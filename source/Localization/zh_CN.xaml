<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

	<!-- General -->
	<sys:String x:Key="LOCSystemChecker">系统配置检查器 - SystemChecker</sys:String>
	<sys:String x:Key="LOCSystemCheckerCheckConfig">检查系统要求</sys:String>
	<sys:String x:Key="LOCSystemCheckerRefreshPcInfo">刷新系统信息</sys:String>

	<!-- Game Details View -->
	<sys:String x:Key="LOCSystemCheckerConfigMinimum">最低配置</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigRecommended">推荐配置</sys:String>
	<sys:String x:Key="LOCSystemCheckerOS">操作系统</sys:String>
	<sys:String x:Key="LOCSystemCheckerCpu">处理器</sys:String>
	<sys:String x:Key="LOCSystemCheckerRam">内存</sys:String>
	<sys:String x:Key="LOCSystemCheckerGpu">图形</sys:String>
	<sys:String x:Key="LOCSystemCheckerDisk">存储</sys:String>

	<!-- Search -->
	<sys:String x:Key="LOCSystemCheckerSearchDescription">搜索 SystemChecker 数据</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">Parameters:
    -min		Matches minimum requirements
    -rec		Matches recommended requirements
    -any		Matches minimum or recommended requirements
    -np		Never played
    -fav		Favorites only
    -stores={n}	Filter by store (e.g. -stores=steam / -stores=steam,epic)
    -status={n}	Filter by play status (e.g. -status=played / -status=played,playing)</sys:String>

	<!-- Search Results -->
	<sys:String x:Key="LOCSystemCheckerSearchMeetsMinimum">✅ 满足最低配置要求</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchMeetsRecommended">✅ 满足推荐配置要求</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchBelowMinimum">⚠️ 低于最低配置要求</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchNoData">ℹ️ 没有可用的配置要求数据</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchSecondaryAction">查看详情</sys:String>

	<!-- Notifications -->
	<sys:String x:Key="LOCSystemCheckerTryRefresh">尝试刷新 {0} 的插件数据</sys:String>
	<sys:String x:Key="LOCSystemCheckerAddTagError">添加标签时出错。请重试。</sys:String>
	<sys:String x:Key="LOCSystemCheckerRemoveTagError">删除标签时出错。请重试。</sys:String>
	<sys:String x:Key="LOCSystemCheckerClearAllError">清除插件数据时出错。请重试。</sys:String>

</ResourceDictionary>
