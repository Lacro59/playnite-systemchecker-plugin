<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

	<!-- General -->
	<sys:String x:Key="LOCSystemChecker">System-Checker</sys:String>
	<sys:String x:Key="LOCSystemCheckerCheckConfig">Systemvoraussetzungen prüfen</sys:String>
	<sys:String x:Key="LOCSystemCheckerRefreshPcInfo">Systeminformationen aktualisieren</sys:String>

	<!-- Settings — PC configuration -->
	<sys:String x:Key="LOCSystemCheckerPcConfigDescription">SystemChecker compares game requirements against your PC hardware. Values below are detected automatically; you can override the processor and graphics card names when detection is incorrect or not recognized by benchmarks.</sys:String>
	<sys:String x:Key="LOCSystemCheckerDetectedHardware">Detected hardware</sys:String>
	<sys:String x:Key="LOCSystemCheckerManualOverrides">Manual overrides</sys:String>
	<sys:String x:Key="LOCSystemCheckerManualOverrideHint">Leave a field empty to use the detected value. Type a name or open the PassMark list to choose a benchmark entry.</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickBenchmark">PassMark list…</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickCpu">Select processor (PassMark)</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickGpu">Select graphics card (PassMark)</sys:String>
	<sys:String x:Key="LOCSystemCheckerBenchmarkSearch">Search benchmarks</sys:String>
	<sys:String x:Key="LOCSystemCheckerBenchmarkLoading">Loading benchmark list…</sys:String>
	<sys:String x:Key="LOCSystemCheckerRetagOnManualConfigChange">Update compatibility tags when manual CPU or GPU settings change</sys:String>

	<!-- Game Details View -->
	<sys:String x:Key="LOCSystemCheckerConfigBelowMinimum">Below Minimum</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigMinimum">Minimum</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigRecommended">Empfohlen</sys:String>
	<sys:String x:Key="LOCSystemCheckerOS">Betriebssystem</sys:String>
	<sys:String x:Key="LOCSystemCheckerCpu">Processor</sys:String>
	<sys:String x:Key="LOCSystemCheckerRam">Memory</sys:String>
	<sys:String x:Key="LOCSystemCheckerGpu">Graphics</sys:String>
	<sys:String x:Key="LOCSystemCheckerDisk">Storage</sys:String>

	<!-- Search -->
	<sys:String x:Key="LOCSystemCheckerSearchDescription">Systemprüfdaten durchsuchen</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">Parameter:
    -min		Pc unterstützt Mindestanforderungen
    -rec		Pc unterstützt empfohlene Anforderungen
    -any		Pc unterstützt minimale oder empfohlene Anforderungen
    -np		Sie haben das Spiel nicht gespielt
    -fav		Das Spiel muss ein Favorit sein
    -stores={n}	Nach Store Name filtern  (ex:-stores=steam / -stores=steam,epic)
    -status={n}	Nach Status Name filtern (ex:-status=played / -status=played,playing)</sys:String>

	<!-- Search Results -->
	<sys:String x:Key="LOCSystemCheckerSearchMeetsMinimum">✅ erfüllt Mindestanforderungen</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchMeetsRecommended">✅ Erfüllt die empfohlenen Anforderungen</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchBelowMinimum">: Warnung: Unter Mindestanforderungen</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchNoData">i keine Voraussetzungen verfügbar</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchSecondaryAction">Details anzeigen</sys:String>

	<!-- Notifications -->
	<sys:String x:Key="LOCSystemCheckerTryRefresh">Versuche die Plugin-Daten für {0} zu aktualisieren</sys:String>
	<sys:String x:Key="LOCSystemCheckerAddTagError">Beim Hinzufügen von Tags ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.</sys:String>
	<sys:String x:Key="LOCSystemCheckerRemoveTagError">Beim Entfernen der Tags ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.</sys:String>
	<sys:String x:Key="LOCSystemCheckerClearAllError">Beim Löschen der Plugin-Daten ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.</sys:String>

</ResourceDictionary>
