<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainView -->

    <sys:String x:Key="LOCSystemChecker">وارس سامانه</sys:String>

    <sys:String x:Key="LOCSystemCheckerCheckConfig">بررسی پیکربندی</sys:String>
    
    <sys:String x:Key="LOCSystemCheckerRefreshPcInfo">پیکربندی رایانهٔ خود را به‌روزرسانی کنید</sys:String>

    <!-- SystemCheckerSettingsView -->

    <sys:String x:Key="LOCSystemCheckerAddTag">برچسبی را اضافه کنید تا نشان دهد کدام تنظیمات درست </sys:String>

    <!-- SystemCheckerGameView -->

    <sys:String x:Key="LOCSystemCheckerConfigMinimum">سیستم حداقلی</sys:String>
    <sys:String x:Key="LOCSystemCheckerConfigRecommanded">سیستم پیشنهادی</sys:String>

    <sys:String x:Key="LOCSystemCheckerOS">سیستم عا</sys:String>
    <sys:String x:Key="LOCSystemCheckerCpu">پردازنده</sys:String>
    <sys:String x:Key="LOCSystemCheckerRam">حافظه</sys:String>
    <sys:String x:Key="LOCSystemCheckerGpu">کارت گرافیک</sys:String>
    <sys:String x:Key="LOCSystemCheckerDisk">فضای ذخیره‌سازی</sys:String>

    <!-- SystemCheckerNotifications -->

    <sys:String x:Key="LOCSystemCheckerTryRefresh">نوگردانی دادهٔ افزایه برای {0} را بیازمایید</sys:String>

    <!-- SystemCheckerSearch -->

    <sys:String x:Key="LOCSystemCheckerSearchDescription">جستجو در دادهٔ وارس سامانه</sys:String>
    <sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">پارامترها:
    -min                رایانهٔ شما دارای پیش‌نیازهای حداقلی است
    -rec                 رایانهٔ شما دارای پیش‌نیازهای پیشنهادی است
    -any                 رایانهٔ شما دارای پیش‌نیازهای حداقلی یا پیشنهادی است
    -np                  بازی را انجام ندادید
    -fav                این بازی شاید از دلخواه‌ها باشد
    -stores={n}     پالایش بر پایهٔ فروشگاه (ex:-stores=steam / -stores=steam,epic)
    -status={n}	پالایش بر پایهٔ نام وضعیت (ex:-status=played / -status=played,playing)</sys:String>

</ResourceDictionary>
