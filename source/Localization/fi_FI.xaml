<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainView -->

    <sys:String x:Key="LOCSystemChecker">SystemChecker</sys:String>

    <sys:String x:Key="LOCSystemCheckerCheckConfig">Check configuration</sys:String>
    
    <sys:String x:Key="LOCSystemCheckerRefreshPcInfo">Refresh your system configuration</sys:String>

    <!-- SystemCheckerSettingsView -->

    <sys:String x:Key="LOCSystemCheckerAddTag">Add a tag to indicate which configuration was successful</sys:String>

    <!-- SystemCheckerGameView -->

    <sys:String x:Key="LOCSystemCheckerConfigMinimum">Minimi</sys:String>
    <sys:String x:Key="LOCSystemCheckerConfigRecommanded">Suositeltu</sys:String>

    <sys:String x:Key="LOCSystemCheckerOS">Käyttöjärjestelmä</sys:String>
    <sys:String x:Key="LOCSystemCheckerCpu">Suoritin</sys:String>
    <sys:String x:Key="LOCSystemCheckerRam">Muisti</sys:String>
    <sys:String x:Key="LOCSystemCheckerGpu">Grafiikka</sys:String>
    <sys:String x:Key="LOCSystemCheckerDisk">Tallennustila</sys:String>

    <!-- SystemCheckerNotifications -->

    <sys:String x:Key="LOCSystemCheckerTryRefresh">Yritä päivittää lisäosan tiedot {0} varten</sys:String>

    <!-- SystemCheckerSearch -->

    <sys:String x:Key="LOCSystemCheckerSearchDescription">Etsi SystemCheckerin tiedoista</sys:String>
    <sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">Parameters:
    -min                Your PC has minimum requirements
    -rec                Your PC has recommended requirements
    -any                Your PC has minimum or recommended requirements
    -np                 You didn't play the game
    -fav                The game must be a favorite
    -stores={n}     Filter by store name (ex:-stores=steam / -stores=steam,epic)</sys:String>

</ResourceDictionary>
