<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

	<!-- General -->
	<sys:String x:Key="LOCSystemChecker">SystemChecker</sys:String>
	<sys:String x:Key="LOCSystemCheckerCheckConfig">Vérifier la configuration requise</sys:String>
	<sys:String x:Key="LOCSystemCheckerRefreshPcInfo">Rafraîchir les informations système</sys:String>

	<!-- Settings — PC configuration -->
	<sys:String x:Key="LOCSystemCheckerPcConfigDescription">SystemChecker compare les exigences des jeux avec le matériel de votre PC. Les valeurs ci-dessous sont détectées automatiquement ; vous pouvez remplacer les noms du processeur et de la carte graphique lorsque la détection est incorrecte ou non reconnue par les benchmarks.</sys:String>
	<sys:String x:Key="LOCSystemCheckerDetectedHardware">Matériel détecté</sys:String>
	<sys:String x:Key="LOCSystemCheckerManualOverrides">Remplacements manuels</sys:String>
	<sys:String x:Key="LOCSystemCheckerManualOverrideHint">Laissez un champ vide pour utiliser la valeur détectée. Saisissez un nom ou ouvrez la liste PassMark pour choisir une entrée de benchmark.</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickBenchmark">Liste PassMark…</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickCpu">Sélectionner le processeur (PassMark)</sys:String>
	<sys:String x:Key="LOCSystemCheckerPickGpu">Sélectionner la carte graphique (PassMark)</sys:String>
	<sys:String x:Key="LOCSystemCheckerBenchmarkSearch">Rechercher des benchmarks</sys:String>
	<sys:String x:Key="LOCSystemCheckerBenchmarkLoading">Chargement de la liste des benchmarks…</sys:String>
	<sys:String x:Key="LOCSystemCheckerRetagOnManualConfigChange">Mettre à jour les étiquettes de compatibilité lorsque les paramètres manuels du processeur ou de la carte graphique changent</sys:String>

	<!-- Game Details View -->
	<sys:String x:Key="LOCSystemCheckerConfigBelowMinimum">En dessous du minimum</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigMinimum">Minimum</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigRecommended">Recommandé</sys:String>
	<sys:String x:Key="LOCSystemCheckerOS">Système d'exploitation</sys:String>
	<sys:String x:Key="LOCSystemCheckerCpu">Processeur</sys:String>
	<sys:String x:Key="LOCSystemCheckerRam">Mémoire</sys:String>
	<sys:String x:Key="LOCSystemCheckerGpu">Graphiques</sys:String>
	<sys:String x:Key="LOCSystemCheckerDisk">Stockage</sys:String>

	<!-- Search -->
	<sys:String x:Key="LOCSystemCheckerSearchDescription">Recherche les données SystemChecker</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">Paramètres :
    -min		Correspond aux exigences minimales
    -rec		Correspond aux exigences recommandées
    -any 		Correspond aux exigences minimales ou recommandées
    -np		Jamais joué
    -fav		Favoris uniquement
    -stores={n}		Filtrer par boutique (par ex. -stores=steam / -stores=steam,epic)
    -status={n}		Filtrer par statut de jeu (par ex. -status=played / -status=played,playing)</sys:String>

	<!-- Search Results -->
	<sys:String x:Key="LOCSystemCheckerSearchMeetsMinimum">✅ Remplit les exigences minimales</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchMeetsRecommended">✅ Remplit les exigences recommandées</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchBelowMinimum">⚠️ En-dessous des exigences minimales</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchNoData">ℹ️ Aucune donnée de prérequis disponible</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchSecondaryAction">Afficher les détails</sys:String>

	<!-- Notifications -->
	<sys:String x:Key="LOCSystemCheckerTryRefresh">Essayer d'actualiser les données du plugin pour {0}</sys:String>
	<sys:String x:Key="LOCSystemCheckerAddTagError">Une erreur s'est produite lors de l'ajout des étiquettes. Veuillez réessayer.</sys:String>
	<sys:String x:Key="LOCSystemCheckerRemoveTagError">Une erreur s'est produite lors de la suppression des étiquettes. Veuillez réessayer.</sys:String>
	<sys:String x:Key="LOCSystemCheckerClearAllError">Une erreur s'est produite lors de l'effacement des données du plugin. Veuillez réessayer.</sys:String>

</ResourceDictionary>
