<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

	<!-- General -->
	<sys:String x:Key="LOCSystemChecker">SystemChecker</sys:String>
	<sys:String x:Key="LOCSystemCheckerCheckConfig">Verifica Requisiti Di Sistema</sys:String>
	<sys:String x:Key="LOCSystemCheckerRefreshPcInfo">Aggiorna Informazioni Di Sistema</sys:String>

	<!-- Game Details View -->
	<sys:String x:Key="LOCSystemCheckerConfigMinimum">Minimum</sys:String>
	<sys:String x:Key="LOCSystemCheckerConfigRecommended">Consigliato</sys:String>
	<sys:String x:Key="LOCSystemCheckerOS">Sistema operativo</sys:String>
	<sys:String x:Key="LOCSystemCheckerCpu">Processor</sys:String>
	<sys:String x:Key="LOCSystemCheckerRam">Memory</sys:String>
	<sys:String x:Key="LOCSystemCheckerGpu">Graphics</sys:String>
	<sys:String x:Key="LOCSystemCheckerDisk">Storage</sys:String>

	<!-- Search -->
	<sys:String x:Key="LOCSystemCheckerSearchDescription">Cerca dati del Controllo di sistema</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">Parametri:
    -min		Corrisponde ai requisiti minimi
    -rec		Corrisponde ai requisiti raccomandati
    -any		Corrisponde ai requisiti minimi o consigliati
    -np		Non ha mai giocato
    -fav		Preferiti solo
    -stores={n}Filtro per negozio (e. . -stores=steam / -stores=steam,epic)
    -status={n}	Filtra per stato di riproduzione (es. -status=played / -status=played,playing)</sys:String>

	<!-- Search Results -->
	<sys:String x:Key="LOCSystemCheckerSearchMeetsMinimum">✅ Soddisfa i requisiti minimi</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchMeetsRecommended">✅ Soddisfa i requisiti raccomandati</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchBelowMinimum">⚠️ Sotto i requisiti minimi</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchNoData">ℹ️ Non sono disponibili dati sui requisiti</sys:String>
	<sys:String x:Key="LOCSystemCheckerSearchSecondaryAction">Visualizza dettagli</sys:String>

	<!-- Notifications -->
	<sys:String x:Key="LOCSystemCheckerTryRefresh">Prova ad aggiornare i dati del plugin per {0}</sys:String>
	<sys:String x:Key="LOCSystemCheckerAddTagError">Si è verificato un errore durante l'aggiunta di tag. Per favore riprova.</sys:String>
	<sys:String x:Key="LOCSystemCheckerRemoveTagError">Si è verificato un errore durante la rimozione dei tag. Per favore riprova.</sys:String>
	<sys:String x:Key="LOCSystemCheckerClearAllError">Si è verificato un errore durante la cancellazione dei dati del plugin. Per favore riprova.</sys:String>

</ResourceDictionary>
