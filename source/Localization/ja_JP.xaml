<?xml version="1.0"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainView -->

    <sys:String x:Key="LOCSystemChecker">適合性チェック</sys:String>

    <sys:String x:Key="LOCSystemCheckerCheckConfig">構成を確認</sys:String>
    
    <sys:String x:Key="LOCSystemCheckerRefreshPcInfo">ステム構成を更新</sys:String>

    <!-- SystemCheckerSettingsView -->

    <sys:String x:Key="LOCSystemCheckerAddTag">どの設定が成功したかを示すタグを追加</sys:String>

    <!-- SystemCheckerGameView -->

    <sys:String x:Key="LOCSystemCheckerConfigMinimum">最低要件</sys:String>
    <sys:String x:Key="LOCSystemCheckerConfigRecommanded">推奨要件</sys:String>

    <sys:String x:Key="LOCSystemCheckerOS">OS</sys:String>
    <sys:String x:Key="LOCSystemCheckerCpu">ロセッサー</sys:String>
    <sys:String x:Key="LOCSystemCheckerRam">モリ</sys:String>
    <sys:String x:Key="LOCSystemCheckerGpu">ラフィ</sys:String>
    <sys:String x:Key="LOCSystemCheckerDisk">トレージ</sys:String>

    <!-- SystemCheckerNotifications -->

    <sys:String x:Key="LOCSystemCheckerTryRefresh">{0} のプラグインデータを更新してください</sys:String>

    <!-- SystemCheckerSearch -->

    <sys:String x:Key="LOCSystemCheckerSearchDescription">SystemChecker データで検索</sys:String>
    <sys:String x:Key="LOCSystemCheckerSearchHint" xml:space="preserve">パラメータ:
    -min		お使いのPCは最低動作環境を満たしています
    -rec		お使いのPCは推奨要件を満たしています
    -any		お使いのPCは最低要件または推奨要件を満たしています
    -np		あなたはゲームをプレイしませんでした
    -fav		ゲームはお気に入りである必要があります
    -stores={n}    ストア名でフィルタリング（例:-stores=steam / -stores=steam,epic）
    -status={n}    ステータス名でフィルタリング（例：-status=played / -status=played,playing）</sys:String>

</ResourceDictionary>
