<UserControl x:Class="SystemChecker.Views.SystemCheckerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:AttachedProperties="clr-namespace:CommonPluginsShared.Controls"
             xmlns:uiServices="clr-namespace:CommonPluginsShared.Commands"
             xmlns:SystemChecker="clr-namespace:SystemChecker"
             mc:Ignorable="d" d:DesignWidth="650"
             d:DataContext="{d:DesignInstance SystemChecker:SystemCheckerSettingsViewModel}">

    <TabControl Margin="20">

        <!-- ═══════════════════════════════════════════════════════════
             TAB 1: General plugin settings
             ═══════════════════════════════════════════════════════════ -->
        <TabItem Header="{DynamicResource LOCSystemChecker}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                <StackPanel>

                    <!-- SECTION: Plugin menu placement -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCCommonMisc}" />

                            <!-- Menu placement toggle — requires restart -->
                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                      IsChecked="{Binding Settings.MenuInExtensions}"
                                      Command="{x:Static uiServices:CommandsPlugin.CmdRestartRequired}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource Self}}">
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                           Text="{DynamicResource LOCCommonMenuInExtensions}" />
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Tag management -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCCommonTagSectionTitle}" />

                            <!--
                                DockPanel replaces the former broken Grid with Grid.Column="2" on a Grid
                                that had no ColumnDefinitions. DockPanel cleanly separates the checkbox
                                (left) from the action buttons (right) without column index errors.
                            -->
                            <DockPanel LastChildFill="True" Margin="0,0,0,4">

                                <!-- Add / Remove tag buttons docked to the right -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource PrimaryButton}"
                                            Content="{DynamicResource LOCAddTitle}"
                                            Margin="0,0,8,0"
                                            Command="{Binding CmdAddTag}" />
                                    <Button Style="{StaticResource WarningButton}"
                                            Content="{DynamicResource LOCRemoveTitle}"
                                            Command="{Binding CmdRemoveTag}" />
                                </StackPanel>

                                <!-- Enable tag checkbox fills remaining space on the left -->
                                <CheckBox Style="{StaticResource ModernCheckBox}"
                                          IsChecked="{Binding Settings.EnableTag}"
                                          VerticalAlignment="Center">
                                    <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                               Text="{DynamicResource LOCCommonAddTag}" />
                                </CheckBox>
                            </DockPanel>

                            <!-- Auto-import on library update -->
                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                      IsChecked="{Binding Settings.AutoImport}">
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                           Text="{DynamicResource LOCCommonAutoImport}" />
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Data management — destructive action isolated in its own card -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCCommonDataSectionTitle}" />

                            <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"
                                       Text="{DynamicResource LOCCommonClearAllDescription}" />

                            <!-- Clear all data — WarningButton signals destructive intent -->
                            <Button Style="{StaticResource WarningButton}"
                                    Content="{DynamicResource LOCClearAll}"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CmdClearAll}" />
                        </StackPanel>
                    </Border>

					<!-- SECTION: Cache management — non-destructive, no data loss -->
					<Border Style="{StaticResource SectionBorder}">
						<StackPanel>
							<TextBlock Style="{DynamicResource SectionHeaderText}"
                                Text="{DynamicResource LOCCommonCacheSectionTitle}" />

							<TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrushDarker}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Text="{DynamicResource LOCCommonClearCacheDescription}" />

							<Button Style="{StaticResource WarningButton}"
                                Content="{DynamicResource LOCCommonClearCache}"
                                HorizontalAlignment="Right"
                                Command="{Binding CmdClearCache}" />
						</StackPanel>
					</Border>

				</StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════════
             TAB 2: PC hardware configuration
             ═══════════════════════════════════════════════════════════ -->
        <TabItem Header="{DynamicResource LOCMenuConfigurationTitle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                <StackPanel>

                    <Border Style="{StaticResource SectionBorder}">
                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrushDarker}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource LOCSystemCheckerPcConfigDescription}" />
                    </Border>

                    <!-- SECTION: WMI-detected hardware (read-only) -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCSystemCheckerDetectedHardware}"
                                       Margin="0,0,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerOS}"
                                           Style="{DynamicResource ViewColumnLabelText}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DetectedOs}"
                                           Style="{DynamicResource ViewColumnValueText}" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerCpu}"
                                           Style="{DynamicResource ViewColumnLabelText}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding DetectedCpu}"
                                           Style="{DynamicResource ViewColumnValueText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerGpu}"
                                           Style="{DynamicResource ViewColumnLabelText}" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding DetectedGpu}"
                                           Style="{DynamicResource ViewColumnValueText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerRam}"
                                           Style="{DynamicResource ViewColumnLabelText}" />
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding DetectedRam}"
                                           Style="{DynamicResource ViewColumnValueText}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SECTION: Manual CPU / GPU overrides -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCSystemCheckerManualOverrides}"
                                       Margin="0,0,0,6" />

                            <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                       Foreground="{DynamicResource TextBrushDarker}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Text="{DynamicResource LOCSystemCheckerManualOverrideHint}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerCpu}"
                                           Style="{DynamicResource ViewColumnLabelText}"
                                           VerticalAlignment="Center" />
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.ManualCpu, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             MinHeight="34"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="{DynamicResource LOCSystemCheckerPickBenchmark}"
                                            Command="{Binding CmdPickCpu}"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Padding="12,6"
                                            MinHeight="34" />
                                </Grid>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{DynamicResource LOCSystemCheckerGpu}"
                                           Style="{DynamicResource ViewColumnLabelText}"
                                           VerticalAlignment="Center" />
                                <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.ManualGpu, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             MinHeight="34"
                                             Margin="0,0,8,0" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="{DynamicResource LOCSystemCheckerPickBenchmark}"
                                            Command="{Binding CmdPickGpu}"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Padding="12,6"
                                            MinHeight="34" />
                                </Grid>
                            </Grid>

                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                      Margin="0,12,0,0"
                                      IsChecked="{Binding Settings.RetagOnManualConfigChange}"
                                      IsEnabled="{Binding Settings.EnableTag}">
                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           Text="{DynamicResource LOCSystemCheckerRetagOnManualConfigChange}" />
                            </CheckBox>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════════════
             TAB 3: UI integration / appearance settings
             ═══════════════════════════════════════════════════════════ -->
        <TabItem Header="{DynamicResource LOCCommonIntegration}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                <StackPanel>

                    <!-- Section header with description -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Style="{DynamicResource SectionHeaderText}"
                                       Text="{DynamicResource LOCCommonControlsAvailable}" />

                            <!-- ─── EXPANDER: Plugin button in game details ─── -->
                            <Expander Margin="0,0,0,8">
                                <Expander.Style>
                                    <Style TargetType="{x:Type Expander}"
                                           BasedOn="{StaticResource {x:Type Expander}}">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </Expander.Style>

                                <Expander.Header>
                                    <!--
                                        Named element PART_IntegrationButton is referenced below
                                        via ElementName binding to enable/disable sub-options
                                        when the parent checkbox is unchecked.
                                    -->
                                    <CheckBox Style="{StaticResource ModernCheckBox}"
                                              IsChecked="{Binding Settings.EnableIntegrationButton}"
                                              Name="PART_IntegrationButton">
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                   Text="{DynamicResource LOCCommonControlsPluginButtonShow}" />
                                    </CheckBox>
                                </Expander.Header>

                                <Expander.Content>
                                    <!--
                                        Sub-options are disabled when the parent checkbox is unchecked.
                                        FilterCardBorder provides visual indentation and separation
                                        from the Common.xaml shared style library.
                                    -->
                                    <Border Style="{StaticResource FilterCardBorder}"
                                            IsEnabled="{Binding ElementName=PART_IntegrationButton, Path=IsChecked}"
                                            Margin="24,4,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                       Foreground="{DynamicResource TextBrushDarker}"
                                                       Margin="0,0,0,6"
                                                       Text="{DynamicResource LOCCommonIntegrationButtonOptions}" />

                                            <!-- Show details alongside button -->
                                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                                      IsChecked="{Binding Settings.EnableIntegrationButtonDetails}">
                                                <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                           Text="{DynamicResource LOCCommonIntegrationButtonDetails}" />
                                            </CheckBox>
                                        </StackPanel>
                                    </Border>
                                </Expander.Content>
                            </Expander>

                            <!-- ─── EXPANDER: Plugin item in games list view ─── -->
                            <!--
                                HideExpanderArrow="True" because this expander has no sub-options to reveal.
                                The arrow is visually misleading when there is no collapsible content.
                            -->
                            <Expander AttachedProperties:ExpanderAttachedProperties.HideExpanderArrow="True">
                                <Expander.Style>
                                    <Style TargetType="{x:Type Expander}"
                                           BasedOn="{StaticResource {x:Type Expander}}">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </Expander.Style>

                                <Expander.Header>
                                    <CheckBox Style="{StaticResource ModernCheckBox}"
                                              IsChecked="{Binding Settings.EnableIntegrationViewItem}">
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}"
                                                   Text="{DynamicResource LOCCommonControlsPluginViewItemShow}" />
                                    </CheckBox>
                                </Expander.Header>
                            </Expander>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

    </TabControl>
</UserControl>