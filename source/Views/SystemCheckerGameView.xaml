<UserControl x:Class="SystemChecker.Views.SystemCheckerGameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:SystemChecker.Converters"
        xmlns:controls="clr-namespace:SystemChecker.Controls"
        xmlns:pconverters="clr-namespace:CommonPluginsShared.Converters" 
        xmlns:pcontrols="clr-namespace:CommonPluginsControls.Controls"
        mc:Ignorable="d" 
        Background="{DynamicResource WindowBackgourndBrush}"
        d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Converters -->
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <pconverters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>

        <!-- Modern Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header Card Style -->
        <Style x:Key="HeaderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="8,8,8,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header Style -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Section - Aligned with content columns -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Empty space for section title column -->
                <Border Grid.Column="0"/>

                <Border Grid.Column="1" Style="{StaticResource HeaderCardStyle}" Background="#3B4E7A">
                    <TextBlock Text="{DynamicResource LOCMenuConfigurationTitle}" 
                               Style="{StaticResource HeaderTextStyle}"/>
                </Border>

                <!-- Empty space for icon -->
                <Border Grid.Column="2"/>

                <Border Grid.Column="3" Style="{StaticResource HeaderCardStyle}" Background="#1E3A8A">
                    <TextBlock Text="{DynamicResource LOCSystemCheckerConfigMinimum}" 
                               Style="{StaticResource HeaderTextStyle}"/>
                </Border>

                <!-- Empty space for icon -->
                <Border Grid.Column="4"/>

                <Border Grid.Column="5" Style="{StaticResource HeaderCardStyle}" Background="#166534">
                    <TextBlock Text="{DynamicResource LOCSystemCheckerConfigRecommanded}" 
                               Style="{StaticResource HeaderTextStyle}"/>
                </Border>
            </Grid>

            <!-- Main Content -->
            <StackPanel Grid.Row="1">

                <!-- OS Section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource LOCSystemCheckerOS}" 
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding LocalOs}" 
                                   Style="{StaticResource ValueTextStyle}"/>

                        <Canvas Grid.Column="2" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding MinimumOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding MinimumCheckOs}"/>
                        </Canvas>

                        <TextBlock Grid.Column="3" 
                                   Text="{Binding MinimumOs}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding MinimumOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                        <Canvas Grid.Column="4" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding RecommandedOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding RecommandedCheckOs}"/>
                        </Canvas>

                        <TextBlock Grid.Column="5" 
                                   Text="{Binding RecommandedOs}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding RecommandedOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- CPU Section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource LOCSystemCheckerCpu}" 
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding LocalCpu}" 
                                   Style="{StaticResource ValueTextStyle}"/>

                        <Canvas Grid.Column="2" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding MinimumCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding MinimumCheckCpu}"/>
                        </Canvas>

                        <ItemsControl Grid.Column="3" 
                                      ItemsSource="{Binding MinimumCpu}" 
                                      BorderThickness="0"
                                      Visibility="{Binding MinimumCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Canvas Grid.Column="4" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding RecommandedCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding RecommandedCheckCpu}"/>
                        </Canvas>

                        <ItemsControl Grid.Column="5" 
                                      ItemsSource="{Binding RecommandedCpu}" 
                                      BorderThickness="0"
                                      Visibility="{Binding RecommandedCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- RAM Section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource LOCSystemCheckerRam}" 
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding LocalRamUsage}" 
                                   Style="{StaticResource ValueTextStyle}"/>

                        <Canvas Grid.Column="2" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding MinimumRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding MinimumCheckRam}"/>
                        </Canvas>

                        <TextBlock Grid.Column="3" 
                                   Text="{Binding MinimumRamUsage}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding MinimumRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                        <Canvas Grid.Column="4" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding RecommandedRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding RecommandedCheckRam}"/>
                        </Canvas>

                        <TextBlock Grid.Column="5" 
                                   Text="{Binding RecommandedRamUsage}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding RecommandedRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- GPU Section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource LOCSystemCheckerGpu}" 
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Grid.Column="1" 
                                   Text="{Binding LocalGpu}" 
                                   Style="{StaticResource ValueTextStyle}"/>

                        <Canvas Grid.Column="2" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding MinimumGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding MinimumCheckGpu}"/>
                        </Canvas>

                        <ItemsControl Grid.Column="3" 
                                      ItemsSource="{Binding MinimumGpu}" 
                                      BorderThickness="0"
                                      Visibility="{Binding MinimumGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Canvas Grid.Column="4" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding RecommandedGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding RecommandedCheckGpu}"/>
                        </Canvas>

                        <ItemsControl Grid.Column="5" 
                                      ItemsSource="{Binding RecommandedGpu}" 
                                      BorderThickness="0"
                                      Visibility="{Binding RecommandedGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Storage/Disk Section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="{DynamicResource LOCSystemCheckerDisk}" 
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding LocalDisks}" BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding Drive}" Style="{StaticResource ValueTextStyle}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource ValueTextStyle}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding FreeSpaceUsage}" Style="{StaticResource ValueTextStyle}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Canvas Grid.Column="2" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding MinimumStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding MinimumCheckStorage}"/>
                        </Canvas>

                        <TextBlock Grid.Column="3" 
                                   Text="{Binding MinimumStorage}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding MinimumStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                        <Canvas Grid.Column="4" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="{Binding RecommandedStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            <controls:StatusIcon Status="{Binding RecommandedCheckStorage}"/>
                        </Canvas>

                        <TextBlock Grid.Column="5" 
                                   Text="{Binding RecommandedStorage}" 
                                   Style="{StaticResource ValueTextStyle}"
                                   Visibility="{Binding RecommandedStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <!-- Footer -->
            <pcontrols:SourceLinkControl Grid.Row="2"
                            Margin="8,20,8,0"
                            LabelText="{DynamicResource LOCSourceLabel}"
                            SourceLabel="{Binding SourceLabel}"
                            SourceUrl="{Binding SourceUrl}"/>


        </Grid>
    </ScrollViewer>
</UserControl>