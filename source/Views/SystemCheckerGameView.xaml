<UserControl x:Class="SystemChecker.Views.SystemCheckerGameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:SystemChecker.Converters"
        xmlns:controls="clr-namespace:SystemChecker.Controls"
        xmlns:pconverters="clr-namespace:CommonPluginsShared.Converters" 
        xmlns:pcontrols="clr-namespace:CommonPluginsControls.Controls"
        mc:Ignorable="d" 
        Background="{DynamicResource WindowBackgourndBrush}"
        d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <pconverters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <!--
        Styles used (all from Common.xaml) :
          ViewPluginCard        - data row cards with drop shadow
          ViewColumnLabelText   - column label (OS, CPU, RAM...)
          ViewColumnValueText   - data value text
          SectionHeaderText     - column header titles (Configuration, Minimum, Recommended)

        Per the UI styling rules every TextBlock MUST explicitly declare
        Style="{DynamicResource BaseTextBlockStyle}" as a base, or use a
        style that is already BasedOn BaseTextBlockStyle (ViewColumnLabelText,
        ViewColumnValueText, SectionHeaderText all satisfy this requirement).
    -->

    <Border Style="{StaticResource TopSeparatorBorder}">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════
                     COLUMN HEADERS
                     Uses ViewPluginCard (Common) with an inline
                     Background color specific to each column.
                     SectionHeaderText (Common) for the text.
                ════════════════════════════════════════════════ -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: current system configuration -->
                    <Border Grid.Column="1"
                            Style="{DynamicResource ViewPluginCard}"
                            Background="#3B4E7A">
                        <TextBlock Text="{DynamicResource LOCMenuConfigurationTitle}"
                                   Style="{DynamicResource SectionHeaderText}"
                                   HorizontalAlignment="Center"
                                   Margin="0"/>
                    </Border>

                    <!-- Column 2: minimum requirements -->
                    <Border Grid.Column="3"
                            Style="{DynamicResource ViewPluginCard}"
                            Background="#1E3A8A">
                        <TextBlock Text="{DynamicResource LOCSystemCheckerConfigMinimum}"
                                   Style="{DynamicResource SectionHeaderText}"
                                   HorizontalAlignment="Center"
                                   Margin="0"/>
                    </Border>

                    <!-- Column 3: recommended requirements -->
                    <Border Grid.Column="5"
                            Style="{DynamicResource ViewPluginCard}"
                            Background="#166534">
                        <TextBlock Text="{DynamicResource LOCSystemCheckerConfigRecommended}"
                                   Style="{DynamicResource SectionHeaderText}"
                                   HorizontalAlignment="Center"
                                   Margin="0"/>
                    </Border>
                </Grid>

                <!-- ═══════════════════════════════════════════════
                     MAIN CONTENT
                     Each row  = ViewPluginCard (Common).
                     Labels    = ViewColumnLabelText (Common).
                     Values    = ViewColumnValueText (Common).
                     Every TextBlock uses a style BasedOn
                     BaseTextBlockStyle as required by the guidelines.
                ════════════════════════════════════════════════ -->
                <StackPanel Grid.Row="1">

                    <!-- OS row -->
                    <Border Style="{DynamicResource ViewPluginCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource LOCSystemCheckerOS}"
                                       Style="{DynamicResource ViewColumnLabelText}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalOs}"
                                       Style="{DynamicResource ViewColumnValueText}"/>

                            <Canvas Grid.Column="2" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding MinimumOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding MinimumCheckOs}"/>
                            </Canvas>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding MinimumOs}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding MinimumOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                            <Canvas Grid.Column="4" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RecommendedOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding RecommendedCheckOs}"/>
                            </Canvas>

                            <TextBlock Grid.Column="5"
                                       Text="{Binding RecommendedOs}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding RecommendedOs, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- CPU row -->
                    <Border Style="{DynamicResource ViewPluginCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource LOCSystemCheckerCpu}"
                                       Style="{DynamicResource ViewColumnLabelText}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalCpu}"
                                       Style="{DynamicResource ViewColumnValueText}"/>

                            <Canvas Grid.Column="2" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding MinimumCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding MinimumCheckCpu}"/>
                            </Canvas>

                            <ItemsControl Grid.Column="3"
                                          ItemsSource="{Binding MinimumCpu}"
                                          BorderThickness="0"
                                          Visibility="{Binding MinimumCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{DynamicResource ViewColumnValueText}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Canvas Grid.Column="4" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RecommendedCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding RecommendedCheckCpu}"/>
                            </Canvas>

                            <ItemsControl Grid.Column="5"
                                          ItemsSource="{Binding RecommendedCpu}"
                                          BorderThickness="0"
                                          Visibility="{Binding RecommendedCpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{DynamicResource ViewColumnValueText}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- RAM row -->
                    <Border Style="{DynamicResource ViewPluginCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource LOCSystemCheckerRam}"
                                       Style="{DynamicResource ViewColumnLabelText}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalRamUsage}"
                                       Style="{DynamicResource ViewColumnValueText}"/>

                            <Canvas Grid.Column="2" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding MinimumRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding MinimumCheckRam}"/>
                            </Canvas>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding MinimumRamUsage}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding MinimumRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                            <Canvas Grid.Column="4" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RecommendedRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding RecommendedCheckRam}"/>
                            </Canvas>

                            <TextBlock Grid.Column="5"
                                       Text="{Binding RecommendedRamUsage}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding RecommendedRamUsage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- GPU row -->
                    <Border Style="{DynamicResource ViewPluginCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource LOCSystemCheckerGpu}"
                                       Style="{DynamicResource ViewColumnLabelText}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalGpu}"
                                       Style="{DynamicResource ViewColumnValueText}"/>

                            <Canvas Grid.Column="2" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding MinimumGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding MinimumCheckGpu}"/>
                            </Canvas>

                            <ItemsControl Grid.Column="3"
                                          ItemsSource="{Binding MinimumGpu}"
                                          BorderThickness="0"
                                          Visibility="{Binding MinimumGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{DynamicResource ViewColumnValueText}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Canvas Grid.Column="4" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RecommendedGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding RecommendedCheckGpu}"/>
                            </Canvas>

                            <ItemsControl Grid.Column="5"
                                          ItemsSource="{Binding RecommendedGpu}"
                                          BorderThickness="0"
                                          Visibility="{Binding RecommendedGpu, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{DynamicResource ViewColumnValueText}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Storage row -->
                    <Border Style="{DynamicResource ViewPluginCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource LOCSystemCheckerDisk}"
                                       Style="{DynamicResource ViewColumnLabelText}"/>

                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding LocalDisks}"
                                          BorderThickness="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{Binding Drive}"
                                                       Style="{DynamicResource ViewColumnValueText}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{DynamicResource ViewColumnValueText}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding FreeSpaceUsage}"
                                                       Style="{DynamicResource ViewColumnValueText}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Canvas Grid.Column="2" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding MinimumStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding MinimumCheckStorage}"/>
                            </Canvas>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding MinimumStorage}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding MinimumStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                            <Canvas Grid.Column="4" Width="24" Height="24"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RecommendedStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                <controls:StatusIcon Status="{Binding RecommendedCheckStorage}"/>
                            </Canvas>

                            <TextBlock Grid.Column="5"
                                       Text="{Binding RecommendedStorage}"
                                       Style="{DynamicResource ViewColumnValueText}"
                                       Visibility="{Binding RecommendedStorage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- Footer: source link -->
                <pcontrols:SourceLinkControl Grid.Row="2"
                            Margin="8,20,8,0"
                            LabelText="{DynamicResource LOCSourceLabel}"
                            SourceLabel="{Binding SourceLabel}"
                            SourceUrl="{Binding SourceUrl}"/>

            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
